{
  "name": "meetwit",
  "version": "1.0.0",
  "private": true,
  "description": "Privacy-first, local-first AI meeting assistant for macOS.",
  "license": "MIT",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm -F meetwit-desktop dev",
    "build": "pnpm -F meetwit-desktop build",
    "lint": "pnpm -F meetwit-desktop lint",
    "typecheck": "pnpm -F meetwit-desktop typecheck",
    "tauri": "pnpm -F meetwit-desktop tauri",
    "tauri:dev": "pnpm -F meetwit-desktop tauri dev",
    "tauri:build": "pnpm -F meetwit-desktop tauri build"
  }
}
