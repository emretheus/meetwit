{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Meetwit",
  "version": "1.0.1",
  "identifier": "ai.meetwit.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Meetwit",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://localhost:* http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Privacy-first AI meeting assistant.",
    "longDescription": "Meetwit listens to live meetings, indexes your local company documents, and answers questions in real time using both. Everything runs locally on your machine.",
    "copyright": "© 2026 Meetwit contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries/python-backend": "python-backend"
    },
    "macOS": {
      "minimumSystemVersion": "13.0",
      "frameworks": [],
      "entitlements": "entitlements.plist",
      "exceptionDomain": null,
      "signingIdentity": null,
      "providerShortName": null
    },
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    }
  }
}
