# Default — autodetect, normalize to LF on commit
* text=auto eol=lf

# Explicit text files
*.rs       text eol=lf
*.toml     text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.json     text eol=lf
*.py       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.md       text eol=lf
*.sh       text eol=lf
*.swift    text eol=lf
*.css      text eol=lf
*.html     text eol=lf

# Binary assets
*.wav      binary
*.mp3      binary
*.onnx     binary
*.bin      binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.ico      binary
*.icns     binary
*.pdf      binary
*.docx     binary
*.dylib    binary
*.so       binary
*.a        binary
*.mlmodel  binary
*.mlmodelc binary
